# Gradle
.gradle
**/build/
!**/src/**/build/
gradle-app.setting
.gradletasknamecache

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar
!gradle-wrapper.properties

# Local configuration (machine/user specific, never commit)
local.properties

# Signing (never commit keystore or its credentials)
keystore.properties
*.jks
*.keystore

# Build outputs
*.apk
*.aab
release/

# Android Studio / IntelliJ
.idea/
*.iml
.navigation/
captures/
.externalNativeBuild/
.cxx/

# Eclipse Gradle plugin generated files
.project
.classpath

# OS files
.DS_Store
